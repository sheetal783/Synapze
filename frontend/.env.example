# ============================================================
# MITS Synapze — Frontend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.
# ============================================================

# URL of the backend API (no trailing slash)
VITE_API_URL=http://localhost:5000/api

# URL of the Socket.IO server for real-time features (no trailing slash)
VITE_SOCKET_URL=http://localhost:5000

# Firebase Client SDK (frontend)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: mirror backend domain restriction on client-side validation
VITE_RESTRICT_EMAIL_DOMAIN=false
