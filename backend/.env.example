# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/mits_Synapze

# Optional DNS override for mongodb+srv environments that block SRV lookups
DNS_SERVERS=8.8.8.8,1.1.1.1

# JWT Configuration
# IMPORTANT: Change JWT_SECRET to a strong random string in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_CHANGE_THIS
JWT_EXPIRE=7d

# Firebase Admin SDK (for hybrid Firebase + JWT auth)
# Prefer one JSON string or use the 3 explicit fields below.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Optional: restrict registration/login to institute email domains only
# Set true in production if you want strict domain enforcement.
RESTRICT_EMAIL_DOMAIN=false

# Optional: temporary dummy admin bootstrap for local testing only
ENABLE_DUMMY_ADMIN=false
DUMMY_ADMIN_NAME=Synapze Admin
DUMMY_ADMIN_EMAIL=admin@synapze.dev
DUMMY_ADMIN_PASSWORD=ChangeThisStrongPassword123!

# Optional: additional admin emails (comma-separated)
ADMIN_EMAILS=
